# PanPilot — Required environment variables
# Copy to .env and fill in values before starting the service
# .env is gitignored — never commit actual values

# Proactivanet API
PROACTIVANET_API_URL=https://your-instance.proactivanet.com/panet/api
PROACTIVANET_BASE_URL=https://your-instance.proactivanet.com/panet
PROACTIVANET_API_KEY=
# UUID of the Proactivanet technician account PanPilot uses to post annotations.
# Find in Proactivanet admin interface: Administración → Técnicos → select PanPilot user → copy Id.
PROACTIVANET_AUTHOR_ID=

# Anthropic
ANTHROPIC_API_KEY=

# Admin interface (HTTP Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Thresholds
CONFIDENCE_THRESHOLD=0.85
CLARIFICATION_MAX=2
REMINDER_MAX_PER_TICKET=2
REMINDER_ORG_WINDOW_DAYS=3
STALE_THRESHOLD_P1_HOURS=4
STALE_THRESHOLD_P2_HOURS=24
STALE_THRESHOLD_P3_HOURS=120
STALE_ALERT_POLL_MINUTES=10

# Idempotency key source for webhook deduplication.
# Set to the JSON field name in the webhook payload containing a unique delivery ID.
# Leave empty to use the fallback: sha256(ticket_id + event_type + DateLastModified).
# NEVER derive from receive timestamp alone — that is not idempotent.
WEBHOOK_IDEMPOTENCY_FIELD=

# UUID of the Proactivanet custom field used for manual exclusion (T13).
# A Proactivanet admin must create a custom field on the Incident entity
# and provide its UUID here. Leave empty to use the text-marker fallback
# ("[panpilot-manual]" in the ticket Description field).
MANUAL_EXCLUSION_FIELD_ID=

# Dry-run mode — set to false only after Week 2 validation
DRY_RUN=true

# Data directory (SQLite files)
DATA_DIR=data
