# PanPilot — Required environment variables
# Copy to .env and fill in values before starting the service
# .env is gitignored — never commit actual values

# Proactivanet API
PROACTIVANET_API_URL=https://your-instance.proactivanet.com/api
PROACTIVANET_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Admin interface (HTTP Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Thresholds
CONFIDENCE_THRESHOLD=0.85
CLARIFICATION_MAX=2
REMINDER_MAX_PER_TICKET=2
REMINDER_ORG_WINDOW_DAYS=3
STALE_THRESHOLD_P1_HOURS=4
STALE_THRESHOLD_P2_HOURS=24
STALE_THRESHOLD_P3_HOURS=120
STALE_ALERT_POLL_MINUTES=10

# Dry-run mode — set to false only after Week 2 validation
DRY_RUN=true

# Data directory (SQLite files)
DATA_DIR=data
