[Unit]
Description=PanPilot AI Complement for Proactivanet
After=network.target

[Service]
Type=simple
User=YOUR_USERNAME
WorkingDirectory=/home/YOUR_USERNAME/panpilot
EnvironmentFile=/home/YOUR_USERNAME/panpilot/.env
ExecStart=/home/YOUR_USERNAME/panpilot/.venv/bin/uvicorn panpilot.intake.webhook:app \
    --host 127.0.0.1 --port 8000 --workers 1
# --workers 1 is required: APScheduler uses a SQLite job store;
# multiple workers each create a scheduler instance causing duplicate stale alerts.
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
